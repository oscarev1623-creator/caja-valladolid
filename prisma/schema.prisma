generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadsAssigned    Lead[]
  ticketsAssigned  Ticket[]
  ticketsCreated   Ticket[] @relation("TicketCreator")
  notes            Note[]
  ticketNotes      TicketNote[]
  documents        Document[]
}

model Lead {
  id              String   @id @default(cuid())
  fullName        String
  phone           String
  email           String?
  estimatedAmount Float?
  creditType      String   @default("TRADITIONAL")
  message         String?
  uniqueToken     String?   @unique
  tokenExpiresAt  DateTime?
  tokenGeneratedAt DateTime?
  
  firstName       String?
  lastName        String?
  contactoPreferido String?
  selectedCrypto  String?
  plazo           Int?
  proposito       String?
  
  status          String   @default("PENDING_CONTACT")
  formType        String   @default("PRE_EVALUATION")
  source          String   @default("WEB_FORM")
  documentsSubmitted Boolean @default(false)
  hasChatHistory  Boolean @default(false)
  
  contactedAt     DateTime?
  docsSubmittedAt DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])

  tickets   Ticket[]
  notes     Note[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([status])
}

model Ticket {
  id           String   @id @default(cuid())
  ticketNumber String   @unique
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status       String   @default("PENDING")
  priority     String   @default("MEDIUM")
  uniqueToken  String   @unique
  linkUrl      String

  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], name: "TicketCreator")

  notes TicketNote[]

  sentAt      DateTime?
  expiresAt   DateTime
  accessedAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id         String   @id @default(cuid())
  content    String
  isInternal Boolean  @default(true)

  leadId   String
  lead     Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model TicketNote {
  id         String   @id @default(cuid())
  content    String
  isInternal Boolean  @default(true)

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model Document {
  id           String   @id @default(cuid())
  filename     String
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedAt   DateTime @default(now())
  
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}

// 📨 NUEVO MODELO PARA MENSAJES DE CONTACTO
model Message {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String   @db.Text
  status     String   @default("UNREAD") // UNREAD, READ, ARCHIVED
  readAt     DateTime?
  repliedAt  DateTime?
  replySent  Boolean  @default(false)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}