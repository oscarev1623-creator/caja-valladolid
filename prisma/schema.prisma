generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(cuid())
  email           String       @unique
  password        String
  name            String
  role            String       @default("ADMIN")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  documents       Document[]
  leadsAssigned   Lead[]
  notes           Note[]
  ticketsAssigned Ticket[]
  ticketsCreated  Ticket[]     @relation("TicketCreator")
  ticketNotes     TicketNote[]
}

model Lead {
  id                 String     @id @default(cuid())
  fullName           String
  phone              String
  email              String?
  estimatedAmount    Float?
  creditType         String     @default("TRADITIONAL")
  message            String?
  uniqueToken        String?    @unique
  tokenExpiresAt     DateTime?
  tokenGeneratedAt   DateTime?
  firstName          String?
  lastName           String?
  contactoPreferido  String?
  selectedCrypto     String?
  plazo              Int?
  proposito          String?
  status             String     @default("PENDING_CONTACT")
  formType           String     @default("PRE_EVALUATION")
  source             String     @default("WEB_FORM")
  documentsSubmitted Boolean    @default(false)
  hasChatHistory     Boolean    @default(false)
  contactedAt        DateTime?
  docsSubmittedAt    DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  assignedToId       String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  curp               String?
  emailSent          Boolean    @default(false)
  emailSentAt        DateTime?
  whatsappContacted  Boolean    @default(false)
  whatsappNumber     String?
  documents          Document[]
  assignedTo         User?      @relation(fields: [assignedToId], references: [id])
  notes              Note[]
  tickets            Ticket[]

  @@index([email])
  @@index([phone])
  @@index([curp])
  @@index([status])
}

model Document {
  id           String   @id @default(cuid())
  filename     String
  fileUrl      String
  fileType     String
  fileSize     Int
  uploadedAt   DateTime @default(now())
  leadId       String
  uploadedById String?
  documentType String
  filePath     String?
  mimeType     String?
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([leadId])
  @@index([documentType])
}

model Ticket {
  id           String       @id @default(cuid())
  ticketNumber String       @unique
  leadId       String
  status       String       @default("PENDING")
  priority     String       @default("MEDIUM")
  uniqueToken  String       @unique
  linkUrl      String
  assignedToId String?
  createdById  String
  sentAt       DateTime?
  expiresAt    DateTime
  accessedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])
  createdBy    User         @relation("TicketCreator", fields: [createdById], references: [id])
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  notes        TicketNote[]
}

model Note {
  id         String   @id @default(cuid())
  content    String
  isInternal Boolean  @default(true)
  leadId     String
  authorId   String
  createdAt  DateTime @default(now())
  author     User     @relation(fields: [authorId], references: [id])
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model TicketNote {
  id         String   @id @default(cuid())
  content    String
  isInternal Boolean  @default(true)
  ticketId   String
  authorId   String
  createdAt  DateTime @default(now())
  author     User     @relation(fields: [authorId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Message {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String    @default("UNREAD")
  readAt    DateTime?
  repliedAt DateTime?
  replySent Boolean   @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}
